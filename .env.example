# Copy to .env or run deploy/start_service.sh / deploy/start_service.ps1 to generate it.

# Public hostname handled by Caddy. Use a real DNS name for HTTPS on a server.
PUBLIC_HOST=astell.example.com
ACME_EMAIL=admin@example.com

# Legacy Caddy Basic Auth fields. Current Caddyfile delegates authentication
# to the Astell app so multiple admin/employee accounts can work.
BASIC_AUTH_USER=astell
BASIC_AUTH_HASH='unused-app-auth-handled-by-astell'

# App-level Basic Auth fallback for accidental direct access to port 8080.
ASTELL_AUTH_ENABLED=1
ASTELL_AUTH_USER=astell
ASTELL_AUTH_PASSWORD_SHA256=replace-with-sha256-of-the-same-password
# Optional multi-account table. Format:
# username:sha256-password:role,employee:sha256-password:employee
ASTELL_AUTH_USERS_SHA256=
ASTELL_AUTH_REALM=Astell Library
ASTELL_ADMIN_USERS=astell
ASTELL_EMPLOYEE_USERS=employee

# Comma-separated allowed browser origins. For public deployments, keep this
# matched to the external URL.
ASTELL_CORS_ORIGINS=https://astell.example.com

ASTELL_UI_HOST=0.0.0.0
ASTELL_UI_PORT=8080
ASTELL_OPEN_BROWSER=0
